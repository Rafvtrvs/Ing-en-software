# ============================================================
#  Variables de entorno del backend (capa Controladores)
# ============================================================

# Servidor HTTPS (Node.js + TypeScript)
PORT=4000

# Conexión BD -> Cloud SQL PostgreSQL (Transaccional)
# En desarrollo apunta a un PostgreSQL local (gratis). En producción se
# reemplaza por la cadena de Cloud SQL sin tocar el código.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/camus_lda?schema=public"

# Autenticación (JWT). El diagrama usa Firebase Auth; en modo local se
# emiten JWT propios. Si AUTH_PROVIDER=firebase se valida contra Firebase.
AUTH_PROVIDER=local
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=8h

# Origen permitido para CORS (frontend Vite). Varios orígenes: separar por coma.
# En desarrollo también se acepta cualquier http://localhost:PUERTO automáticamente.
CORS_ORIGIN=http://localhost:5173

# ---- Servicios externos de pago: modo SIMULADO ----
# mock = no se realizan llamadas reales (no requiere pagar / sin tarjeta).
STORAGE_PROVIDER=mock     # firebase | mock
MAIL_PROVIDER=mock        # sendgrid | mailgun | mock
PUSH_PROVIDER=mock        # fcm | mock

# Carpeta donde el storage simulado guarda archivos localmente
STORAGE_LOCAL_DIR=./.storage
